# Copy to .env.local and fill values

GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Base site URL used for absolute OG/Twitter URLs
# e.g. https://zassha.example.com
NEXT_PUBLIC_SITE_URL=

# Optional: Gemini model configuration
# Model name (default: gemini-2.5-flash-lite)
GEMINI_MODEL=gemini-2.5-flash-lite

# Temperature for model generation (default: 0.4, range: 0.0-1.0)
GEMINI_TEMPERATURE=0.4

# Maximum output tokens (default: 4000)
GEMINI_MAX_OUTPUT_TOKENS=8000

# Optional: Video segmentation (requires ffmpeg in PATH)
# Split videos into segments of specified length in seconds
# Set to 0 to disable segmentation and process whole video (default: 0)
# Recommended: 60-120 seconds for long videos
ZASSHA_SEGMENT_LEN=60

# Optional: Upload chunking configuration
# Files larger than this threshold will be uploaded in chunks (default: 50 MB)
ZASSHA_CHUNK_THRESHOLD_BYTES=52428800

# Size of each upload chunk (default: 5 MB)
ZASSHA_CHUNK_SIZE_BYTES=5242880
